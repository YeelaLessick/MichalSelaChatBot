# .streamlit/secrets.toml
# ⚠️ DO NOT COMMIT THIS FILE — it contains credentials.
# On Streamlit Community Cloud, paste these values into the app's Secrets settings.

[postgres]
host = "your-server.postgres.database.azure.com"
port = "5432"
database = "chatbot"
user = "your_pg_user"
password = "YOUR_PASSWORD_HERE"
sslmode = "require"
# Set to "true" to use Azure AD auth instead of a password.
use_aad = "false"
